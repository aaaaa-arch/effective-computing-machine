-- [[ 自动收集 ]]
local function ToggleAutoCollect(state)
    States.AutoCollect = state
    
    if state then
        spawn(function()
            while States.AutoCollect do
                local myRoot = GetRootPart()
                if myRoot then
                    for _, obj in pairs(Workspace:GetDescendants()) do
                        if obj:IsA("Model") or obj:IsA("Part") then
                            local name = string.lower(obj.Name)
                            if name:find("coin") or name:find("cash") or name:find("money") 
                               or name:find("gem") or name:find("orb") or name:find("collect")
                               or name:find("drop") or name:find("item") or name:find("loot") then
                                
                                local objRoot = obj:IsA("Model") and obj:FindFirstChildWhichIsA("BasePart") or obj
                                if objRoot and objRoot:IsA("BasePart") then
                                    local dist = (objRoot.Position - myRoot.Position).Magnitude
                                    if dist < 100 then
                                        objRoot.CFrame = myRoot.CFrame
                                    end
                                end
                            end
                        end
                    end
                end
                wait(0.5)
            end
        end)
        Notify("自动收集", "自动收集已开启", 3)
    else
        Notify("自动收集", "自动收集已关闭", 3)
    end
end

