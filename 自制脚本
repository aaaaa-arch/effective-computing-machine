-- [[ ESP透视系统 ]]
local ESP_Objects = {}

local function ToggleESP(state)
    States.ESP = state
    
    if state then
        spawn(function()
            while States.ESP do
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                        
                        if hrp and not ESP_Objects[player] then
                            local highlight = Instance.new("Highlight")
                            highlight.Name = "ScriptHub_ESP"
                            highlight.FillColor = Config.ESP_Color
                            highlight.FillTransparency = 0.7
                            highlight.OutlineColor = Config.ESP_Color
                            highlight.OutlineTransparency = 0
                            highlight.Adornee = player.Character
                            highlight.Parent = LocalPlayer.PlayerGui
                            
                            local billboard = Instance.new("BillboardGui")
                            billboard.Name = "ScriptHub_ESP_Name"
                            billboard.Size = UDim2.new(0, 200, 0, 50)
                            billboard.StudsOffset = Vector3.new(0, 3, 0)
                            billboard.AlwaysOnTop = true
                            billboard.Adornee = hrp
                            billboard.Parent = LocalPlayer.PlayerGui
                            
                            local nameText = Instance.new("TextLabel")
                            nameText.Size = UDim2.new(1, 0, 0.5, 0)
                            nameText.BackgroundTransparency = 1
                            nameText.TextColor3 = Color3.new(1, 1, 1)
                            nameText.TextStrokeTransparency = 0
                            nameText.Font = Enum.Font.GothamBold
                            nameText.TextScaled = true
                            nameText.Text = player.Name
                            nameText.Parent = billboard
                            
                            local distText = Instance.new("TextLabel")
                            distText.Name = "Distance"
                            distText.Size = UDim2.new(1, 0, 0.5, 0)
                            distText.Position = UDim2.new(0, 0, 0.5, 0)
                            distText.BackgroundTransparency = 1
                            distText.TextColor3 = Color3.new(1, 1, 0)
                            distText.TextStrokeTransparency = 0
                            distText.Font = Enum.Font.Gotham
                            distText.TextScaled = true
                            distText.Text = "0m"
                            distText.Parent = billboard
                            
                            ESP_Objects[player] = {highlight, billboard}
                        end
                        
                        if ESP_Objects[player] then
                            local myRoot = GetRootPart()
                            if myRoot and hrp then
                                local dist = math.floor((hrp.Position - myRoot.Position).Magnitude)
                                local billboard = ESP_Objects[player][2]
                                local distLabel = billboard:FindFirstChild("Distance")
                                if distLabel then
                                    distLabel.Text = dist .. "m"
                                end
                            end
                        end
                    end
                end
                
                for player, objects in pairs(ESP_Objects) do
                    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
                        for _, obj in pairs(objects) do
                            if obj and obj.Parent then obj:Destroy() end
                        end
                        ESP_Objects[player] = nil
                    end
                end
                
                RunService.RenderStepped:Wait()
            end
        end)
        
        Notify("ESP", "ESP透视已开启", 3)
    else
        for _, objects in pairs(ESP_Objects) do
            for _, obj in pairs(objects) do
                if obj and obj.Parent then obj:Destroy() end
            end
        end
        ESP_Objects = {}
        Notify("ESP", "ESP透视已关闭", 3)
    end
end

-- [[ 自瞄系统 ]]
local function ToggleAimbot(state)
    States.Aimbot = state
    
    if state then
        spawn(function()
            while States.Aimbot do
                local closestPlayer = nil
                local closestAngle = Config.Aimbot_FOV
                local myRoot = GetRootPart()
                
                if myRoot then
                    local cameraCF = Camera.CFrame
                    local lookVector = cameraCF.LookVector
                    
                    for _, player in pairs(Players:GetPlayers()) do
                        if player ~= LocalPlayer and player.Character then
                            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
                            local targetHum = player.Character:FindFirstChild("Humanoid")
                            
                            if targetRoot and targetHum and targetHum.Health > 0 then
                                local toTarget = (targetRoot.Position - myRoot.Position).Unit
                                local angle = math.deg(math.acos(lookVector:Dot(toTarget)))
                                
                                if angle < closestAngle then
                                    closestAngle = angle
                                    closestPlayer = player
                                end
                            end
                        end
                    end
                end
                
                if closestPlayer and closestPlayer.Character then
                    local targetHead = closestPlayer.Character:FindFirstChild("Head")
                    if targetHead then
                        local targetPos = targetHead.Position
                        local currentPos = Camera.CFrame.Position
                        local newCF = CFrame.lookAt(currentPos, targetPos)
                        
                        local alpha = 1 / Config.Aimbot_Smoothness
                        Camera.CFrame = Camera.CFrame:Lerp(newCF, alpha)
                    end
                end
                
                RunService.RenderStepped:Wait()
            end
        end)
        
        Notify("自瞄", "自瞄已开启 (FOV: " .. Config.Aimbot_FOV .. ")", 3)
    else
        Notify("自瞄", "自瞄已关闭", 3)
    end
end

