-- 聊天命令系统
-- ══════════════════════════════════════════════

local Commands = {
    ["fly"] = function() LaunchFly() end,
    ["speed"] = function(args)
        if args[1] then
            Config.Speed = tonumber(args[1]) or 50
        end
        ToggleSpeed(not States.Speeding)
    end,
    ["noclip"] = function() ToggleNoclip(not States.Noclip) end,
    ["esp"] = function() ToggleESP(not States.ESP) end,
    ["aimbot"] = function() ToggleAimbot(not States.Aimbot) end,
    ["god"] = function() ToggleGodMode(not States.GodMode) end,
    ["invis"] = function() ToggleInvisible(not States.Invisible) end,
    ["fullbright"] = function() ToggleFullbright(not States.Fullbright) end,
    ["tp"] = function(args)
        if args[1] then
            TeleportToPlayer(table.concat(args, " "))
        else
            Notify("错误", "用法: /tp [玩家名]", 3)
        end
    end,
    ["jump"] = function(args)
        local power = tonumber(args[1]) or 100
        Config.JumpPower = power
        ToggleSuperJump(true)
    end,
    ["help"] = function()
        local helpText = "=== 命令列表 ===\n"
            .. "/fly - 飞行(XY脚本)\n"
            .. "/speed [值] - 加速\n"
            .. "/noclip - 穿墙\n"
            .. "/esp - ESP透视\n"
            .. "/aimbot - 自瞄\n"
            .. "/god - 无敌\n"
            .. "/invis - 隐身\n"
            .. "/fullbright - 全图亮\n"
            .. "/tp [名字] - 传送\n"
            .. "/jump [值] - 跳跃增强\n"
        Notify("帮助", helpText, 10)
    end,
}

-- 聊天命令监听
LocalPlayer.Chatted:Connect(function(message)
    if message:sub(1, 1) == "/" then
        local parts = {}
        for word in message:sub(2):gmatch("%S+") do
            table.insert(parts, word)
        end
        
        local cmd = parts[1]
        local args = {}
        for i = 2, #parts do
            table.insert(args, parts[i])
        end
        
        if Commands[cmd] then
            Commands[cmd](args)
        end
    end
end)

